{
  "include": ["src/**/*", "test/**/*.test.ts"],
  "exclude": ["test/*.ui.ts", "test/utils/**"],
  "compilerOptions": {
    "strict": true,
    /* ── Migration overrides (re-enable as codebase is fixed) ── */
    "noImplicitAny": false,
    "noImplicitOverride": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": "./src",
    "jsx": "react",
    "lib": ["esnext", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noErrorTruncation": true,
    "pretty": true,
    "sourceMap": true,
    "target": "es2022",
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["long", "resize-observer-browser", "@decentralchain/cubensisconnect-types"]
  }
}

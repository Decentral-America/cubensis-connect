{
  "include": ["src/**/*", "test/**/*.test.ts"],
  "exclude": ["test/*.ui.ts", "test/utils/**"],
  "compilerOptions": {
    "strict": true,
    /* ── Migration overrides (re-enable as JS→TS codebase is fully typed) ── */
    "noImplicitAny": false,
    "noImplicitOverride": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,

    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": "./src",
    "paths": {
      "@decentralchain/transactions": ["../node_modules/@decentralchain/transactions/dist"],
      "@decentralchain/transactions/*": ["../node_modules/@decentralchain/transactions/dist/*"]
    },
    "jsx": "react",
    "lib": ["esnext", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noErrorTruncation": true,
    "pretty": true,
    "sourceMap": true,
    "target": "es2022",
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["long", "node", "resize-observer-browser", "@decentralchain/cubensis-connect-types"]
  }
}

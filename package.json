    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "axios": "^1.7.9",
    "serialize-javascript": "^7.0.3",
    "follow-redirects": "^1.15.9",
    "semver": "^7.6.3",
    "json5": "^2.2.3",
    "loader-utils": "^2.0.4",
    "node-forge": "^1.3.3"
  }
}

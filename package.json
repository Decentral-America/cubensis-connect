{
  "name": "@decentralchain/cubensis-connect",
  "version": "3.0.0",
  "description": "Browser extension that signs transactions and manages wallets for DecentralChain",
  "author": "DecentralChain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/cubensis-connect.git"
  },
  "homepage": "https://github.com/Decentral-America/cubensis-connect#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/cubensis-connect/issues"
  },
  "license": "MIT",
  "type": "module",
  "private": true,
  "engineStrict": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "dist": "vite build --mode production",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bulletproof": "npm run format && npm run lint && npm run typecheck && npm run test",
    "bulletproof:check": "npm run format:check && npm run lint:check && npm run typecheck && npm run test",
    "knip": "knip --use-tsconfig-files --no-exit-code",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@decentralchain/bignumber": "1.1.1",
    "@decentralchain/data-entities": "3.0.0",
    "@decentralchain/parse-json-bignumber": "2.0.0",
    "@decentralchain/signature-adapter": "7.0.0",
    "@decentralchain/transactions": "5.0.0",
    "@decentralchain/ts-types": "2.0.0",
    "@popperjs/core": "^2.11.0",
    "circle-progress-bar": "^1.0.0",
    "classnames": "^2.3.1",
    "color-hash": "^2.0.1",
    "copy-to-clipboard": "^3.3.1",
    "debounce": "^3.0.0",
    "debounce-stream": "^2.0.0",
    "dnode": "^1.2.2",
    "events": "^3.3.0",
    "extensionizer": "^1.0.1",
    "highlight.js": "^11.3.1",
"i18next": "^25.8.13"
    "i18next-http-backend": "^3.0.2",
    "identity-img": "^2.0.0",
    "loglevel": "^1.7.1",
    "long": "^5.2.0",
    "obj-multiplex": "^1.0.0",
    "obs-store": "^4.0.3",

    "post-message-stream": "^3.0.0",
    "protobufjs": "^8.0.0",
    "pump": "^3.0.0",
    "qrcode": "^1.4.4",
    "ramda": "^0.32.0",
"react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-imask": "^7.6.1",
    "react-popper": "^2.2.5",
    "react-redux": "^9.2.0",
    "react-transition-group": "^4.4.2",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "readable-stream": "^4.7.0",
    "redux": "^5.0.1",
    "url": "^0.11.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
"@decentralchain/cubensis-connect-types": "1.0.0",
    "@eslint/js": "^10.0.1",
    "@sentry/react": "^10.42.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.3",
    "@types/resize-observer-browser": "^0.1.6",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "folder-zip": "0.0.5",
    "globals": "^17.4.0",

    "husky": "^9.1.0",
    "jsdom": "28.1.0",
    "knip": "5.85.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.5.0",
    "stream-browserify": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.25.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "axios": "^1.7.9",
    "serialize-javascript": "7.0.4",
    "follow-redirects": "^1.15.9",
    "semver": "^7.6.3",
    "json5": "^2.2.3",
    "loader-utils": "^2.0.4"
  }
}

    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "folder-zip": "0.0.5",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.0",
    "jsdom": "28.1.0",
    "knip": "5.85.0",
    "lint-staged": "^16.3.1",
    "mini-css-extract-plugin": "^2.9.2",

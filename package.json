{
  "name": "cubensis-connect",
  "version": "3.0.0",
  "description": "Browser extension that signs transactions and manages wallets for DecentralChain",
  "author": "DecentralChain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/cubensis-connect.git"
  },
  "homepage": "https://github.com/Decentral-America/cubensis-connect#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/cubensis-connect/issues"
  },
  "license": "MIT",
  "private": true,
  "engineStrict": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "webpack --watch",
    "dist": "NODE_ENV=production webpack",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bulletproof": "npm run format && npm run lint && npm run typecheck && npm run test",
    "bulletproof:check": "npm run format:check && npm run lint:check && npm run typecheck && npm run test",
    "knip": "knip --use-tsconfig-files --no-exit-code",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@decentralchain/bignumber": "npm:@waves/bignumber@^1.0.0",
    "@decentralchain/data-entities": "npm:@waves/data-entities@^2.0.4",
    "@decentralchain/signature-adapter": "6.1.7",
    "@decentralchain/ts-types": "npm:@waves/ts-types@^0.3.3",
    "@decentralchain/transactions": "4.2.3",
    "@popperjs/core": "^2.11.0",
    "circle-progress-bar": "^1.0.0",
    "classnames": "^2.3.1",
    "color-hash": "^2.0.1",
    "copy-to-clipboard": "^3.3.1",
    "debounce": "^3.0.0",
    "debounce-stream": "^2.0.0",
    "dnode": "^1.2.2",
    "events": "^3.3.0",
    "extensionizer": "^1.0.1",
    "highlight.js": "^11.3.1",
    "i18next": "^25.8.13",
    "i18next-http-backend": "^3.0.2",
    "identity-img": "^2.0.0",
    "loglevel": "^1.7.1",
    "long": "^5.2.0",
    "obj-multiplex": "^1.0.0",
    "obs-store": "^4.0.3",
    "parse-json-bignumber": "^1.0.0",
    "post-message-stream": "^3.0.0",
    "protobufjs": "^8.0.0",
    "pump": "^3.0.0",
    "qrcode": "^1.4.4",
    "ramda": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-imask": "^7.6.1",
    "react-popper": "^2.2.5",
    "react-redux": "^9.2.0",
    "react-transition-group": "^4.4.2",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "readable-stream": "^4.7.0",
    "redux": "^5.0.1",
    "url": "^0.11.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@decentralchain/cubensisconnect-types": "^0.2.1",
    "@decentralchain/signature-generator": "npm:@waves/signature-generator@^5.2.1",
    "@eslint/js": "^10.0.1",
    "@sentry/react": "^10.41.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.20",
    "@types/react-transition-group": "^4.4.3",
